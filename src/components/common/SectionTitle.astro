---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const centered = align === 'center';
---

<div class:list={["max-w-2xl", centered && 'mx-auto text-center']}>
  {eyebrow && <p class="mb-3 text-xs uppercase tracking-[0.28em] text-muted">{eyebrow}</p>}
  <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-zinc-400">{description}</p>}
</div>
