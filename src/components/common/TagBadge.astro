---
interface Props {
  tag: string;
  count?: number;
  large?: boolean;
}

const { tag, count, large = false } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] text-zinc-200 shadow-soft backdrop-blur transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-white',
    large ? 'px-4 py-2.5 text-sm' : 'px-3 py-1.5 text-xs'
  ]}
>
  <span class="h-1.5 w-1.5 rounded-full bg-cyan-300"></span>
  <span>{tag}</span>
  {typeof count === 'number' && <span class="text-zinc-500">{count}</span>}
</span>
