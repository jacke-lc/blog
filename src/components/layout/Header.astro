---
import Container from '@/components/common/Container.astro';
import { siteConfig } from '@/lib/site';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-white/8 bg-[#050816]/75 backdrop-blur-xl">
  <Container class="flex min-h-16 flex-col justify-center gap-4 py-4 sm:min-h-20 sm:flex-row sm:items-center sm:justify-between sm:py-0">
    <a href="/" class="inline-flex items-center gap-3 text-sm font-medium tracking-[0.2em] text-white uppercase">
      <span class="flex h-9 w-9 items-center justify-center rounded-full border border-cyan-400/20 bg-cyan-400/10 text-xs text-cyan-200">JA</span>
      <span>{siteConfig.name}</span>
    </a>

    <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-zinc-400">
      {siteConfig.nav.map((item) => {
        const isActive = item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);

        return (
          <a
            href={item.href}
            class:list={[
              'transition hover:text-white',
              isActive && 'text-cyan-200'
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </Container>
</header>
