---
import Container from '@/components/common/Container.astro';
import { siteConfig } from '@/lib/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-10">
  <Container class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm uppercase tracking-[0.24em] text-muted">{siteConfig.name}</p>
      <p class="mt-3 max-w-xl text-sm leading-7 text-zinc-400">{siteConfig.description}</p>
    </div>

    <div class="flex flex-col gap-3 text-sm text-zinc-400 md:items-end">
      <div class="flex flex-wrap gap-4">
        {siteConfig.socialLinks.map((link) => (
          <a href={link.href} class="hover:text-white" target={link.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer">
            {link.label}
          </a>
        ))}
      </div>
      <p>© {year} {siteConfig.name}. All rights reserved.</p>
    </div>
  </Container>
</footer>
