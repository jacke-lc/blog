---
import PostMeta from '@/components/blog/PostMeta.astro';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      tags?: string[];
      featured?: boolean;
    };
  };
}

const { post } = Astro.props;
---

<article class="group rounded-3xl border border-white/8 bg-white/[0.03] p-6 transition hover:border-white/15 hover:bg-white/[0.05]">
  <div class="flex items-start justify-between gap-4">
    <div>
      {post.data.featured && <p class="mb-3 text-xs uppercase tracking-[0.28em] text-muted">Featured</p>}
      <h3 class="text-2xl font-semibold tracking-tight text-white">
        <a href={`/blog/${post.slug}`} class="hover:text-zinc-300">{post.data.title}</a>
      </h3>
    </div>
  </div>
  <p class="relative mt-4 text-sm leading-7 text-zinc-400">{post.data.description}</p>
  <div class="relative mt-6">
    <PostMeta date={post.data.pubDate} tags={post.data.tags} />
  </div>
</article>
