---
import Container from '@/components/common/Container.astro';
import TagBadge from '@/components/common/TagBadge.astro';
import SectionTitle from '@/components/common/SectionTitle.astro';
import PostCard from '@/components/blog/PostCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getFeaturedPosts } from '@/lib/posts';
import { siteConfig } from '@/lib/site';

const featuredPosts = await getFeaturedPosts(2);
---

<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <section class="py-16 sm:py-24">
    <Container>
      <div class="panel overflow-hidden px-8 py-10 sm:px-10 sm:py-14">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
          <div>
            <p class="text-xs uppercase tracking-[0.32em] text-cyan-300/80">jacke / security & ai</p>
            <h1 class="hero-title mt-6 max-w-4xl text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl">
              网络安全与人工智能
            </h1>
            <p class="mt-6 max-w-2xl text-base leading-8 text-zinc-400 sm:text-lg">
              分享实战观察、研究笔记与方法总结。
            </p>

            <div class="mt-8 flex flex-wrap gap-3">
              {siteConfig.tags.map((label) => <TagBadge tag={label} />)}
            </div>

            <div class="mt-8 flex flex-wrap gap-4">
              <a href="/blog" class="rounded-full border border-cyan-400/25 bg-cyan-400/10 px-6 py-3 text-sm text-white hover:bg-cyan-400/15">浏览文章</a>
              <a href="/about" class="rounded-full border border-white/10 px-6 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">了解更多</a>
            </div>
          </div>

          <div class="panel p-6 sm:p-8">
            <p class="text-xs uppercase tracking-[0.24em] text-cyan-300/80">Focus</p>
            <p class="mt-4 text-2xl font-medium tracking-tight text-white">聚焦两个核心方向</p>
            <p class="mt-4 text-sm leading-7 text-zinc-400">
              网络安全与人工智能。
            </p>
            <div class="mt-6 space-y-3 text-sm text-zinc-500">
              <p>2 个核心方向</p>
              <p>4 个固定标签</p>
              <p>持续更新 Markdown 内容</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-10 sm:py-14">
    <Container>
      <SectionTitle
        eyebrow="Selected Posts"
        title="精选文章"
        description="最近输出的重点内容。"
      />

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {featuredPosts.map((post) => <PostCard post={post} />)}
      </div>
    </Container>
  </section>

  <section class="py-10 sm:py-14">
    <Container>
      <div class="panel grid gap-8 px-8 py-8 sm:px-10 lg:grid-cols-2 lg:items-start">
        <div>
          <p class="text-xs uppercase tracking-[0.3em] text-cyan-300/80">Directions</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">内容方向</h2>
          <p class="mt-4 max-w-xl text-sm leading-8 text-zinc-400">
            安全与人工智能两条主线，其他细分内容通过文章持续延展。
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-3xl border border-white/8 bg-black/20 p-5">
            <p class="text-lg font-semibold text-white">安全</p>
            <p class="mt-3 text-sm leading-7 text-zinc-400">网络安全、数据安全、安全运营。</p>
          </div>
          <div class="rounded-3xl border border-white/8 bg-black/20 p-5">
            <p class="text-lg font-semibold text-white">智能</p>
            <p class="mt-3 text-sm leading-7 text-zinc-400">人工智能、工具实践、自动化工作流。</p>
          </div>
        </div>
      </div>
    </Container>
  </section>

</BaseLayout>
