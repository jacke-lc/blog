---
import Container from '@/components/common/Container.astro';
import SectionTitle from '@/components/common/SectionTitle.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="联系方式 | jacke" description="jacke 的联系方式与交流方式。">
  <section class="py-16 sm:py-24">
    <Container>
      <SectionTitle
        eyebrow="Contact"
        title="联系方式"
        description="后续如有需要再补充邮箱、社交账号或其他交流方式。"
      />

      <div class="panel mt-12 p-8 text-sm leading-8 text-zinc-400">
        暂未开放公开留言与评论功能。
      </div>
    </Container>
  </section>
</BaseLayout>
