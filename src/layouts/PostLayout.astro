---
import Container from '@/components/common/Container.astro';
import PostMeta from '@/components/blog/PostMeta.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}

const { title, description, pubDate, tags = [] } = Astro.props;
---

<BaseLayout title={`${title} | 博客`} description={description}>
  <Container as="article" class="py-16 sm:py-24">
    <div class="mx-auto max-w-3xl">
      <p class="text-xs uppercase tracking-[0.28em] text-muted">Article</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-white sm:text-5xl">{title}</h1>
      <p class="mt-6 text-lg leading-8 text-zinc-400">{description}</p>
      <div class="mt-8 border-t border-white/8 pt-6">
        <PostMeta date={pubDate} tags={tags} />
      </div>

      <div class="prose-shell mt-12">
        <slot />
      </div>
    </div>
  </Container>
</BaseLayout>
